# Telegram token from @BotFather.
TELEGRAM_BOT_TOKEN=123456789:replace_me

# Safety: comma-separated chat IDs where bot is allowed to work.
# Empty means all chats are allowed. Recommended: set this after /start or /stats shows chat_id.
ALLOWED_CHAT_IDS=

# LLM provider: auto, openai, ollama.
# auto uses OpenAI when OPENAI_API_KEY is present, otherwise Ollama.
LLM_PROVIDER=auto

# OpenAI API key. ChatGPT subscription is not enough; API key is billed separately.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Local fallback via Ollama: https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=1800
OLLAMA_KEEP_ALIVE=30m
OLLAMA_UNLOAD_AFTER_TASK=true
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=800

# Models used by /compare, comma-separated. Keep this list short for slow machines.
COMPARE_MODELS=qwen3:14b,gemma3:27b,qwen3-coder:30b

# SQLite database path.
DATABASE_PATH=data/messages.sqlite3
LOG_FILE=data/bot.log
RESPONSE_LOG_FILE=data/responses.log

# Local voice/audio transcription via faster-whisper.
TRANSCRIBE_VOICE=false
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
WHISPER_LANGUAGE=ru
MAX_VOICE_SECONDS=600
VOICE_DOWNLOAD_DIR=data/voice

# Limits to keep summaries fast and predictable.
MAX_MESSAGE_CHARS=4000
MAX_SUMMARY_INPUT_CHARS=50000
CHUNK_CHARS=7000

# Default period for /summary without arguments.
DEFAULT_SUMMARY_PERIOD=24h
