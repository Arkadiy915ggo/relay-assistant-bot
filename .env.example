# Telegram token from @BotFather.
TELEGRAM_BOT_TOKEN=123456789:replace_me

# Safety: comma-separated chat IDs where bot is allowed to work.
# Empty means all chats are allowed. Recommended: set this after /start or /stats shows chat_id.
ALLOWED_CHAT_IDS=

# LLM provider: auto, openai, ollama.
# auto uses OpenAI when OPENAI_API_KEY is present, otherwise Ollama.
LLM_PROVIDER=auto

# OpenAI API key. ChatGPT subscription is not enough; API key is billed separately.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Local fallback via Ollama: https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=1800
OLLAMA_KEEP_ALIVE=30m
OLLAMA_UNLOAD_AFTER_TASK=true
#OLLAMA_NUM_CTX=32768
OLLAMA_NUM_PREDICT=800

# Optional separate model for /question. Empty means use OLLAMA_MODEL.
QUESTION_MODEL=

# Models used by /compare, comma-separated. Keep this list short for slow machines.
COMPARE_MODELS=qwen3:14b,gemma3:27b,qwen3-coder:30b

# SQLite database path.
DATABASE_PATH=data/messages.sqlite3
LOG_FILE=data/bot.log
RESPONSE_LOG_FILE=data/responses.log

# Optional Opik tracing: https://www.comet.com/opik
# When OPIK_ENABLED=true, LLM prompts and outputs are sent to the configured Opik backend
# if OPIK_CAPTURE_CONTENT=true. Use a local/self-hosted Opik instance for private chats.
OPIK_ENABLED=false
OPIK_PROJECT_NAME=telegram-summary-bot
OPIK_CAPTURE_CONTENT=true
# Configure Opik via `opik configure` or env vars such as:
# OPIK_API_KEY=
# OPIK_WORKSPACE=
# OPIK_URL_OVERRIDE=http://localhost:5173/api/

# Local voice/audio transcription via faster-whisper.
TRANSCRIBE_VOICE=false
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
WHISPER_LANGUAGE=ru
MAX_VOICE_SECONDS=600
VOICE_DOWNLOAD_DIR=data/voice
TRANSCRIPTION_FORMAT_ENABLED=true
TRANSCRIPTION_FORMAT_PROVIDER=ollama
TRANSCRIPTION_FORMAT_MODEL=qwen2.5vl:7b
#TRANSCRIPTION_FORMAT_NUM_CTX=32768
TRANSCRIPTION_FORMAT_NUM_PREDICT=4096
MAX_TRANSCRIPTION_FORMAT_CHARS=12000

# Manual image recognition through an Ollama vision model.
# The bot only records incoming image file IDs. OCR runs only when /image or /ocr is used.
IMAGE_RECOGNITION_MODEL=qwen2.5vl:7b
#IMAGE_RECOGNITION_NUM_CTX=32768
MAX_IMAGE_SIZE_MB=20
IMAGE_DOWNLOAD_DIR=data/images

# Manual video recognition through key frames and an Ollama vision model.
# The bot only records incoming video file IDs. Recognition runs only when /video or /vocr is used.
VIDEO_RECOGNITION_MODEL=qwen2.5vl:7b
#VIDEO_RECOGNITION_NUM_CTX=32768
VIDEO_RECOGNITION_NUM_PREDICT=800
MAX_VIDEO_SIZE_MB=50
MAX_VIDEO_SECONDS=120
VIDEO_DOWNLOAD_DIR=data/video
VIDEO_FRAME_DIR=data/video_frames
VIDEO_FRAME_COUNT=8
VIDEO_FRAME_MAX_WIDTH=960
VIDEO_TRANSCRIBE_AUDIO=true

# Limits to keep summaries fast and predictable.
MAX_MESSAGE_CHARS=4000
MAX_TRANSCRIPTION_CHARS=50000
MAX_SUMMARY_INPUT_CHARS=50000
CHUNK_CHARS=7000

# Default period for /summary without arguments.
DEFAULT_SUMMARY_PERIOD=24h

# Structured chat memory for long /question and /summary periods.
# MEMORY_MAX_BLOCKS is per hierarchy level; older blocks are rolled up.
MEMORY_ENABLED=true
MEMORY_RECENT_PERIOD=24h
MEMORY_CHUNK_CHARS=18000
MEMORY_MAX_BLOCKS=200
MEMORY_SEARCH_LIMIT=8
