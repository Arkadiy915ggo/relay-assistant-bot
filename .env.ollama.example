# Recommended local Ollama setup.
# Copy this file to .env, set TELEGRAM_BOT_TOKEN, then run:
#   ./run.sh doctor
#   ./run.sh start
#
# macOS prerequisites:
#   brew install ollama ffmpeg
#   ollama pull llama3.1:8b
#
# Stable model notes from the maintainer's local setup:
# - llama3.1:8b is the safest baseline for text summaries/questions.
# - qwen2.5vl:7b is the stable vision model used for /image, /ocr, /meme, /video frames.
# - qwen3:14b, gemma3:27b, and qwen3-coder:30b are useful for /compare on stronger machines.
# - A Mac with 48 GB unified memory can often run heavier models than a smaller NVIDIA/desktop setup,
#   but start with llama3.1:8b first and increase model size only after ./run.sh doctor passes.

# Telegram token from @BotFather.
TELEGRAM_BOT_TOKEN=123456789:replace_me

# Empty means all chats are allowed. After /stats shows chat_id, restrict this value.
ALLOWED_CHAT_IDS=

# Text LLM through local Ollama.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=1800
OLLAMA_KEEP_ALIVE=30m
OLLAMA_UNLOAD_AFTER_TASK=false
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=800

# Optional separate model for /question. Empty means use OLLAMA_MODEL.
QUESTION_MODEL=

# /compare is optional. Keep empty for a first run.
# On a stronger local machine, pull these first and then uncomment:
#   ollama pull qwen3:14b
#   ollama pull gemma3:27b
#   ollama pull qwen3-coder:30b
#COMPARE_MODELS=qwen3:14b,gemma3:27b,qwen3-coder:30b
COMPARE_MODELS=

# OpenAI-compatible fallback is not used in this local Ollama profile.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# SQLite and logs.
DATABASE_PATH=data/messages.sqlite3
LOG_FILE=data/bot.log
RESPONSE_LOG_FILE=data/responses.log

# Wikipedia search does not need an API key.
WIKI_SEARCH_ENABLED=true
WIKI_LANGUAGE=ru
WIKI_TIMEOUT_SECONDS=20
WIKI_MAX_RESULTS=3
WIKI_USER_AGENT=telegram-summary-bot/0.1 (https://github.com/Arkadiy915ggo/relay-assistant-bot)

# Text-only first-run defaults. Enable media features after the bot works.
TRANSCRIBE_VOICE=false
VIDEO_TRANSCRIBE_AUDIO=false
MEME_ENABLED=false

# Mac-safe Whisper settings for later voice/video transcription.
# Enable with TRANSCRIBE_VOICE=true and/or VIDEO_TRANSCRIBE_AUDIO=true after:
#   ./run.sh install-voice
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=
MAX_VOICE_SECONDS=600
VOICE_DOWNLOAD_DIR=data/voice
TRANSCRIPTION_FORMAT_ENABLED=true
TRANSCRIPTION_FORMAT_PROVIDER=ollama
TRANSCRIPTION_FORMAT_MODEL=qwen2.5vl:7b
TRANSCRIPTION_FORMAT_NUM_CTX=8192
TRANSCRIPTION_FORMAT_NUM_PREDICT=2048
MAX_TRANSCRIPTION_FORMAT_CHARS=12000

# Optional image recognition and memes through qwen2.5vl:7b.
# Enable after: ollama pull qwen2.5vl:7b
#IMAGE_RECOGNITION_MODEL=qwen2.5vl:7b
IMAGE_RECOGNITION_MODEL=
IMAGE_RECOGNITION_NUM_CTX=8192
MAX_IMAGE_SIZE_MB=20
IMAGE_DOWNLOAD_DIR=data/images
MEME_MODEL=
MEME_OUTPUT_DIR=data/memes
MEME_FONT_PATH=
MEME_MAX_IMAGE_SIZE_MB=20
MEME_NUM_PREDICT=160

# Optional video recognition through sampled frames and qwen2.5vl:7b.
# Requires ffmpeg. Audio transcription is disabled by default for simpler first setup.
#VIDEO_RECOGNITION_MODEL=qwen2.5vl:7b
VIDEO_RECOGNITION_MODEL=
VIDEO_RECOGNITION_NUM_CTX=8192
VIDEO_RECOGNITION_NUM_PREDICT=800
MAX_VIDEO_SIZE_MB=50
TELEGRAM_DOWNLOAD_LIMIT_MB=0
MAX_VIDEO_SECONDS=120
VIDEO_DOWNLOAD_DIR=data/video
VIDEO_FRAME_DIR=data/video_frames
VIDEO_FRAME_COUNT=6
VIDEO_FRAME_MAX_WIDTH=768

# Limits to keep local summaries predictable.
MAX_MESSAGE_CHARS=4000
MAX_TRANSCRIPTION_CHARS=50000
MAX_SUMMARY_INPUT_CHARS=50000
CHUNK_CHARS=7000
DEFAULT_SUMMARY_PERIOD=24h

# Structured long-term memory.
MEMORY_ENABLED=true
MEMORY_RECENT_PERIOD=24h
MEMORY_CHUNK_CHARS=12000
MEMORY_MAX_BLOCKS=200
MEMORY_SEARCH_LIMIT=8

# Optional Opik tracing.
OPIK_ENABLED=false
OPIK_PROJECT_NAME=telegram-summary-bot
OPIK_CAPTURE_CONTENT=true
